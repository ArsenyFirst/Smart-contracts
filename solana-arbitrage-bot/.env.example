# =============================================================================
# Jupiter RFQ Arbitrage System - Environment Configuration
# =============================================================================

# Webhook Server Configuration
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080
JUPITER_WEBHOOK_SECRET=your_secret_webhook_key_here

# Jupiter API Configuration
JUPITER_API_KEY=your_jupiter_pro_api_key_here
JUPITER_BASE_URL=https://api.jup.ag

# Solana Configuration
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_PRIVATE_KEY=your_base58_private_key_here

# Database Configuration (если используете)
DATABASE_URL=postgresql://user:password@localhost:5432/jupiter_rfq
REDIS_URL=redis://localhost:6379/0

# Monitoring & Alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/DISCORD/WEBHOOK
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# SSL/TLS Configuration
SSL_CERT_PATH=/path/to/ssl/certificate.crt
SSL_KEY_PATH=/path/to/ssl/private.key

# Application Settings
LOG_LEVEL=INFO
LOG_FILE_PATH=./logs/jupiter_rfq.log
DEBUG_MODE=false
RATE_LIMIT_REQUESTS_PER_SECOND=10

# Security Settings
CORS_ALLOWED_ORIGINS=*
MAX_REQUEST_SIZE=1048576  # 1MB

# Monitoring
GRAFANA_PASSWORD=your_secure_grafana_password
PROMETHEUS_RETENTION_DAYS=30

# Domain Configuration
DOMAIN_NAME=your-domain.com
PUBLIC_WEBHOOK_URL=https://your-domain.com/webhook/jupiter/rfq

# =============================================================================
# Инструкции по настройке:
#
# 1. Скопируйте этот файл в .env
# 2. Заполните все необходимые значения
# 3. Убедитесь что .env файл добавлен в .gitignore
# 4. Для production используйте более безопасные методы хранения секретов
# =============================================================================

# Alternative RPC endpoints (choose one)
# SOLANA_RPC_URL=https://solana-api.projectserum.com
# SOLANA_RPC_URL=https://rpc.ankr.com/solana
# SOLANA_RPC_URL=https://solana.publicnode.com

# Trading Configuration
TRADE_AMOUNT=1000.0
MIN_PROFIT_THRESHOLD_BPS=10
LOOP_INTERVAL_SECONDS=1.0
REQUEST_TIMEOUT_SECONDS=2.0

# Logging Configuration
LOG_TO_FILE=true

# API Configuration (usually don't need to change these)
JUPITER_RFQ_URL=https://quote-api.jup.ag/v6
RAYDIUM_API_URL=https://api-v3.raydium.io
METEORA_API_URL=https://dlmm-api.meteora.ag
ORCA_API_URL=https://api.orca.so/v1