# Solana Configuration
SOLANA_PRIVATE_KEY=your_base58_encoded_private_key_here
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Alternative RPC endpoints (choose one)
# SOLANA_RPC_URL=https://solana-api.projectserum.com
# SOLANA_RPC_URL=https://rpc.ankr.com/solana
# SOLANA_RPC_URL=https://solana.publicnode.com

# Trading Configuration
TRADE_AMOUNT=1000.0
MIN_PROFIT_THRESHOLD_BPS=10
LOOP_INTERVAL_SECONDS=1.0
REQUEST_TIMEOUT_SECONDS=2.0

# Logging Configuration
LOG_LEVEL=INFO
LOG_TO_FILE=true
LOG_FILE_PATH=arbitrage_bot.log

# API Configuration (usually don't need to change these)
JUPITER_RFQ_URL=https://quote-api.jup.ag/v6
RAYDIUM_API_URL=https://api-v3.raydium.io
METEORA_API_URL=https://dlmm-api.meteora.ag
ORCA_API_URL=https://api.orca.so/v1